{
    "name": "workspace-root",
    "version": "0.0.0",
    "author": "Workleap",
    "description": "Common configurations for building web apps and libraries at Workleap",
    "private": true,
    "type": "module",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-web-configs.git"
    },
    "scripts": {
        "dev-webpack": "turbo run dev --filter=./samples/webpack/*",
        "dev-webpack-msw": "turbo run dev-msw --filter=./samples/webpack/*",
        "dev-rsbuild": "turbo run dev --filter=./samples/rsbuild/*",
        "dev-rsbuild-msw": "turbo run dev-msw --filter=./samples/rsbuild/*",
        "dev-storybook-rsbuild": "turbo run dev --filter=./samples/storybook/rsbuild",
        "dev-storybook-rslib": "turbo run dev --filter=./samples/storybook/rslib",
        "dev-docs": "retype start",
        "build-docs": "retype start",
        "build-pkg": "turbo run build --filter=./packages/*",
        "build-webpack": "turbo run build --filter=./samples/webpack/*",
        "build-rsbuild": "turbo run build --filter=./samples/rsbuild/*",
        "build-storybook-rsbuild": "turbo run build --filter=./samples/storybook/rsbuild",
        "build-storybook-rslib": "turbo run build --filter=./samples/storybook/rslib",
        "serve-webpack": "turbo run serve-build --filter=./samples/webpack/*",
        "serve-rsbuild": "turbo run serve-build --filter=./samples/rsbuild/*",
        "serve-storybook-rsbuild": "turbo run serve-build --filter=./samples/storybook/rsbuild",
        "serve-storybook-rslib": "turbo run serve-build --filter=./samples/storybook/rslib",
        "deploy-rsbuild": "cross-env NETLIFY=true turbo run deploy --filter=./samples/rsbuild/app",
        "prelint": "turbo run build --filter=./packages/*",
        "lint": "turbo run lint --continue",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "syncpack": "syncpack lint",
        "test": "turbo run test --continue",
        "changeset": "changeset",
        "publish-pkg": "changeset publish",
        "publish-pr-pkg": "pkg-pr-new publish ./packages/* --packageManager=pnpm --pnpm",
        "clean": "pnpm -r --parallel --include-workspace-root exec pnpm dlx rimraf dist storybook-static .turbo .rslib node_modules/.cache",
        "reset": "pnpm clean && pnpm reset:modules",
        "reset:modules": "pnpm -r --parallel --include-workspace-root exec pnpm dlx rimraf node_modules pnpm-lock.yaml",
        "list-outdated-deps": "pnpm outdated -r --filter=!@webpack-sample/* --format list !eslint !@eslint/js !stylelint !stylelint-config-standard",
        "update-outdated-deps": "pnpm run --sequential \"/^update-outdated-deps:.*/\"",
        "update-outdated-deps:without-webpack-sample": "pnpm update -r --filter=!@webpack-sample/* --latest !eslint !@eslint/js !stylelint !stylelint-config-standard",
        "update-outdated-deps:only-webpackreact-18-sample": "pnpm update -r --filter=@webpack-sample/* --latest !eslint !@eslint/js !stylelint !stylelint-config-standard",
        "update-outdated-deps:update-peers": "syncpack fix",
        "update-outdated-deps:fix-pkg-json": "eslint --fix --no-cache --no-ignore package.json **/package.json"
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.0",
        "@eslint/js": "9.39.2",
        "@types/node": "25.9.1",
        "@typescript-eslint/parser": "8.60.1",
        "@typescript/native-preview": "7.0.0-dev.20260602.1",
        "@workleap/eslint-configs": "workspace:*",
        "@workleap/typescript-configs": "workspace:*",
        "agent-browser": "0.27.0",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "pkg-pr-new": "0.0.75",
        "prettier": "3.8.3",
        "retypeapp": "4.6.0",
        "syncpack": "15.3.1",
        "turbo": "2.9.16",
        "typescript": "6.0.3",
        "typescript-eslint": "8.60.1"
    },
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=11"
    },
    "packageManager": "pnpm@11.0.8"
}
