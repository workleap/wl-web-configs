{
    "name": "@workleap/webpack-configs",
    "author": "Workleap",
    "description": "Workleap recommended webpack configurations.",
    "version": "1.6.13",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workleap/wl-web-configs.git",
        "directory": "packages/webpack-configs"
    },
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "src",
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "rslib build -c rslib.config.ts",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo",
        "test": "vitest --config vitest.config.ts --no-watch"
    },
    "peerDependencies": {
        "@swc/core": "^1.15.43",
        "@swc/helpers": "^0.5.23",
        "browserslist": "^4.28.5",
        "postcss": "^8.5.16",
        "webpack": "^5.106.2",
        "webpack-dev-server": "^5.2.4"
    },
    "peerDependenciesMeta": {
        "webpack-dev-server": {
            "optional": true
        }
    },
    "dependencies": {
        "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
        "@svgr/webpack": "^8.1.0",
        "css-loader": "^7.1.4",
        "html-webpack-plugin": "^5.6.7",
        "mini-css-extract-plugin": "^2.10.2",
        "postcss-loader": "^8.2.1",
        "react-refresh": "^0.18.0",
        "style-loader": "^4.0.0",
        "swc-loader": "^0.2.7",
        "terser-webpack-plugin": "^5.6.1"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "2.1.5",
        "@rslib/core": "0.23.2",
        "@svgr/core": "8.1.0",
        "@types/node": "26.1.0",
        "@typescript-eslint/parser": "8.63.0",
        "@typescript/native-preview": "7.0.0-dev.20260512.1",
        "@workleap/eslint-configs": "workspace:*",
        "@workleap/rslib-configs": "workspace:*",
        "@workleap/swc-configs": "workspace:*",
        "@workleap/typescript-configs": "workspace:*",
        "eslint": "9.39.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.63.0",
        "vitest": "4.1.10"
    }
}
