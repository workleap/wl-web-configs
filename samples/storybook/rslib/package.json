{
    "name": "@storybook-sample/rslib",
    "description": "Storybook app using Rslib as a bundler.",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "storybook dev -p 6006",
        "build": "storybook build",
        "serve-build": "pnpm http-server storybook-static -p 8080 -P http://localhost:8080? -c-1",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo"
    },
    "dependencies": {
        "react": "19.2.5",
        "react-dom": "19.2.5"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "1.7.5",
        "@rslib/core": "0.21.2",
        "@storybook/addon-a11y": "10.3.5",
        "@storybook/react": "10.3.5",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/parser": "8.59.0",
        "@typescript/native-preview": "7.0.0-dev.20260421.1",
        "@workleap/browserslist-config": "workspace:*",
        "@workleap/eslint-configs": "workspace:*",
        "@workleap/rslib-configs": "workspace:*",
        "@workleap/typescript-configs": "workspace:*",
        "browserslist": "4.28.2",
        "eslint": "9.39.2",
        "http-server": "14.1.1",
        "storybook": "10.3.5",
        "storybook-addon-rslib": "3.3.3",
        "storybook-react-rsbuild": "3.3.3",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.0"
    }
}
